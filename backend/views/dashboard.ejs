<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dashboard - Backend Portal</title>
    <style>
      body { font-family: Arial, sans-serif; margin: 0; padding: 0; background: #f4f7fb; color: #2c3e50; }
      .wrapper { max-width: 1000px; margin: 0 auto; padding: 24px; }
      header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }
      .button { background: #2980b9; color: #fff; border: none; border-radius: 12px; padding: 12px 18px; cursor: pointer; }
      .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
      .card { background: #fff; padding: 20px; border-radius: 18px; box-shadow: 0 14px 30px rgba(0,0,0,0.08); }
      .card h2 { margin-top: 0; }
      .form-group { display: grid; gap: 10px; margin-bottom: 14px; }
      .form-group label { font-weight: 600; }
      .form-group input, .form-group textarea, .form-group select { width: 100%; padding: 12px 14px; border: 1px solid #ccd6e3; border-radius: 12px; }
      table { width: 100%; border-collapse: collapse; margin-top: 12px; }
      th, td { text-align: left; padding: 10px; border-bottom: 1px solid #e5eaf0; }
      .small { font-size: 0.95rem; color: #6b7a8f; }
    </style>
  </head>
  <body>
    <div class="wrapper">
      <header>
        <div>
          <h1>Welcome, <%= user.name %></h1>
          <p class="small">This is the backend dashboard for student portal operations.</p>
        </div>
        <form method="post" action="/logout">
          <button class="button" type="submit">Logout</button>
        </form>
      </header>

      <div class="grid">
        <div class="card">
          <h2>Submit Hostel Complaint</h2>
          <form method="post" action="/complaint">
            <div class="form-group">
              <label for="subject">Subject</label>
              <input id="subject" name="subject" type="text" required />
            </div>
            <div class="form-group">
              <label for="message">Message</label>
              <textarea id="message" name="message" rows="5" required></textarea>
            </div>
            <button class="button" type="submit">Send Complaint</button>
          </form>
        </div>

        <div class="card">
          <h2>Send Mess Feedback</h2>
          <form method="post" action="/feedback">
            <div class="form-group">
              <label for="rating">Rating</label>
              <select id="rating" name="rating" required>
                <option value="5">Excellent</option>
                <option value="4">Very Good</option>
                <option value="3">Good</option>
                <option value="2">Average</option>
                <option value="1">Poor</option>
              </select>
            </div>
            <div class="form-group">
              <label for="comments">Comments</label>
              <textarea id="comments" name="comments" rows="5"></textarea>
            </div>
            <button class="button" type="submit">Send Feedback</button>
          </form>
        </div>
      </div>

      <div class="grid" style="margin-top: 24px;">
        <div class="card">
          <h2>Submitted Complaints</h2>
          <table>
            <thead>
              <tr><th>Subject</th><th>Date</th><th>User</th></tr>
            </thead>
            <tbody>
              <% if (complaints.length === 0) { %>
              <tr><td colspan="3">No complaints submitted yet.</td></tr>
              <% } %>
              <% complaints.forEach((item) => { %>
              <tr>
                <td><%= item.subject %></td>
                <td><%= item.date.toLocaleString() %></td>
                <td><%= item.user %></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <div class="card">
          <h2>Feedback Log</h2>
          <table>
            <thead>
              <tr><th>Rating</th><th>Date</th><th>Comments</th></tr>
            </thead>
            <tbody>
              <% if (feedback.length === 0) { %>
              <tr><td colspan="3">No feedback submitted yet.</td></tr>
              <% } %>
              <% feedback.forEach((item) => { %>
              <tr>
                <td><%= item.rating %>/5</td>
                <td><%= item.date.toLocaleString() %></td>
                <td><%= item.comments || '—' %></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </body>
</html>
