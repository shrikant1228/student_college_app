<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Signup - Backend Portal</title>
    <style>
      body { font-family: Arial, sans-serif; margin: 0; padding: 0; background: #eef3fb; color: #2c3e50; }
      .container { max-width: 520px; margin: 60px auto; padding: 24px; }
      .card { background: #fff; padding: 24px; border-radius: 18px; box-shadow: 0 14px 30px rgba(0,0,0,0.08); }
      .field { display: grid; gap: 10px; margin-bottom: 16px; }
      .field label { font-weight: 600; }
      .field input { padding: 12px 14px; border: 1px solid #ccd6e3; border-radius: 12px; }
      .button { padding: 12px 18px; border: none; border-radius: 12px; background: #2980b9; color: #fff; width: 100%; cursor: pointer; }
      .error { color: #c0392b; margin-bottom: 16px; }
      .footer { margin-top: 18px; font-size: 0.95rem; }
      .footer a { color: #2980b9; text-decoration: none; }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="card">
        <h1>Signup</h1>
        <% if (error) { %>
        <div class="error"><%= error %></div>
        <% } %>
        <form method="post" action="/signup">
          <div class="field">
            <label for="name">Name</label>
            <input id="name" name="name" type="text" required />
          </div>
          <div class="field">
            <label for="email">Email</label>
            <input id="email" name="email" type="email" required />
          </div>
          <div class="field">
            <label for="password">Password</label>
            <input id="password" name="password" type="password" required />
          </div>
          <button class="button" type="submit">Create account</button>
        </form>
        <div class="footer">
          <p>Already have an account? <a href="/login">Login</a></p>
        </div>
      </div>
    </div>
  </body>
</html>
