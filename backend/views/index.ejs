<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Backend Student Portal</title>
    <style>
      body { font-family: Arial, sans-serif; margin: 0; padding: 0; background: #f4f6fb; color: #2c3e50; }
      .container { max-width: 900px; margin: 0 auto; padding: 24px; }
      header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }
      .nav a { margin-left: 16px; text-decoration: none; color: #2980b9; font-weight: 600; }
      .card { background: #fff; padding: 24px; border-radius: 18px; box-shadow: 0 16px 32px rgba(0,0,0,0.08); }
      .button { display: inline-block; padding: 12px 18px; background: #2980b9; color: #fff; border-radius: 12px; text-decoration: none; }
    </style>
  </head>
  <body>
    <div class="container">
      <header>
        <div>
          <h1>Student College App Backend</h1>
          <p>Minimal backend pages for login, signup, and dashboard flows.</p>
        </div>
        <nav class="nav">
          <a href="/login">Login</a>
          <a href="/signup">Signup</a>
          <a href="/dashboard">Dashboard</a>
        </nav>
      </header>
      <div class="card">
        <h2>Welcome</h2>
        <p>This backend scaffold serves frontend routes and handles form submission for login, signup, complaints, and feedback.</p>
        <% if (user) { %>
        <p>Signed in as <strong><%= user.name %></strong>.</p>
        <form method="post" action="/logout">
          <button class="button" type="submit">Logout</button>
        </form>
        <% } else { %>
        <a class="button" href="/login">Start</a>
        <% } %>
      </div>
    </div>
  </body>
</html>
